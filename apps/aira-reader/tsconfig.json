{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "preserve",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "references": [
    { "path": "../../packages/npm/aira-core" },
    { "path": "../../packages/npm/aimd-renderer" }
  ]
}
