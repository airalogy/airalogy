{
  "name": "airalogy-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/airalogy/airalogy.git"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:engine-rootfs": "node scripts/airalogy-engine/build-rootfs.mjs",
    "build:engine-rootfs:force": "node scripts/airalogy-engine/build-rootfs.mjs --force",
    "build:npm": "pnpm --filter './packages/npm/*' -r --if-present build",
    "build:python:airalogy": "rm -rf .tmp/python-build/airalogy && UV_CACHE_DIR=.uv-cache uv build --out-dir .tmp/python-build/airalogy packages/pypi/airalogy && rm -rf .tmp/python-build/airalogy",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version && pnpm sync:python-versions && pnpm lock:python",
    "check:python-versions": "node scripts/release/sync-python-versions.mjs --check",
    "dev": "pnpm --filter './packages/npm/*' -r --parallel --if-present dev",
    "dev:demo": "pnpm --filter @airalogy/aimd-demo dev",
    "dev:aira-reader": "pnpm --filter @airalogy/aira-reader dev",
    "dev:aira-reader:desktop": "pnpm --filter @airalogy/aira-reader desktop:dev",
    "dev:protocol-demo": "pnpm --filter @airalogy/protocol-demo dev",
    "dev:protocol-demo:full": "pnpm build:engine-rootfs && pnpm dev:protocol-demo",
    "build:aira-reader": "pnpm --filter @airalogy/aira-reader build",
    "build:aira-reader:desktop": "pnpm --filter @airalogy/aira-reader build:desktop",
    "build:aira-reader:desktop:all": "pnpm --filter @airalogy/aira-reader build:desktop:all",
    "build:aira-reader:desktop:dmg": "pnpm --filter @airalogy/aira-reader build:desktop:dmg",
    "build:protocol-demo": "pnpm --filter @airalogy/protocol-demo build",
    "docs:home:dev": "pnpm -C docs/home docs:dev",
    "docs:home:build": "pnpm -C docs/home docs:build",
    "docs:home:preview": "pnpm -C docs/home docs:preview",
    "docs:airalogy:dev": "pnpm -C docs/airalogy docs:dev",
    "docs:airalogy:build": "pnpm -C docs/airalogy docs:build",
    "docs:airalogy:preview": "pnpm -C docs/airalogy docs:preview",
    "docs:airalogy-engine:dev": "pnpm -C docs/airalogy-engine docs:dev",
    "docs:airalogy-engine:build": "pnpm -C docs/airalogy-engine docs:build",
    "docs:airalogy-engine:preview": "pnpm -C docs/airalogy-engine docs:preview",
    "docs:aimd:dev": "pnpm -C docs/aimd docs:dev",
    "docs:aimd:build": "DEMO_BASE=\"${BASE_PATH%/}/demo/\" pnpm --filter @airalogy/aimd-demo build && pnpm -C docs/aimd docs:build && rm -rf docs/aimd/.vitepress/dist/demo && mkdir -p docs/aimd/.vitepress/dist/demo && cp -R apps/aimd-demo/dist/. docs/aimd/.vitepress/dist/demo/ && node ./scripts/aimd/create-demo-route-shims.mjs",
    "docs:aimd:preview": "pnpm -C docs/aimd docs:preview",
    "lock:python": "UV_CACHE_DIR=.uv-cache uv --directory packages/pypi/airalogy lock && UV_CACHE_DIR=.uv-cache uv --directory packages/pypi/airalogy-engine lock",
    "release:npm": "node scripts/release/publish-npm-packages.mjs",
    "setup:githooks": "git config core.hooksPath .githooks",
    "sync:python-versions": "node scripts/release/sync-python-versions.mjs",
    "test": "pnpm test:npm",
    "test:aira": "pnpm --filter '@airalogy/aira-*' -r --if-present test",
    "test:aimd": "pnpm --filter '@airalogy/aimd-*' -r --if-present test",
    "test:engine-node": "pnpm --filter @airalogy/airalogy-engine test",
    "test:npm": "pnpm test:aimd && pnpm test:aira && pnpm test:engine-node && pnpm test:vitest",
    "test:python:airalogy": "uv --directory packages/pypi/airalogy run pytest tests/",
    "test:python:airalogy:examples": "UV_CACHE_DIR=.uv-cache uv --directory packages/pypi/airalogy run --with pytest python -m pytest tests/test_spec_fixtures.py",
    "test:python:engine": "uv --directory packages/pypi/airalogy-engine run pytest tests/ --sandbox-mode=rootfs",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:vitest:coverage": "vitest run --coverage",
    "type-check": "pnpm --filter './packages/npm/*' -r --if-present type-check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "vitest": "^4.1.0"
  }
}
