{
  "name": "@airalogy/aimd-recorder",
  "type": "module",
  "version": "1.24.1",
  "description": "AIMD (Airalogy Markdown) recorder Vue components and UI",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/airalogy/airalogy.git",
    "directory": "packages/npm/aimd-recorder"
  },
  "bugs": {
    "url": "https://github.com/airalogy/airalogy/issues"
  },
  "homepage": "https://github.com/airalogy/airalogy/tree/main/packages/npm/aimd-recorder#readme",
  "keywords": [
    "aimd",
    "markdown",
    "editor",
    "vue",
    "components"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts"
    },
    "./composables": {
      "types": "./src/composables/index.ts",
      "import": "./src/composables/index.ts"
    },
    "./record": {
      "types": "./src/record/index.ts",
      "import": "./src/record/index.ts"
    },
    "./styles": {
      "import": "./src/styles/recorder.css",
      "default": "./src/styles/recorder.css"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "type-check": "vue-tsc --noEmit",
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "@vueuse/core": "^13.5.0",
    "naive-ui": "2.41.0",
    "vue": "^3.5.17"
  },
  "dependencies": {
    "@airalogy/aimd-core": "workspace:^",
    "@airalogy/aimd-editor": "workspace:^",
    "@airalogy/aimd-renderer": "workspace:^",
    "@milkdown/kit": "^7.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ajv": "catalog:",
    "ajv-formats": "catalog:",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.52.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "seqviz": "^3.10.18"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vueuse/core": "^13.5.0",
    "naive-ui": "2.41.0",
    "sass": "^1.90.0",
    "typescript": "5.8.3",
    "unocss": "^0.58.3",
    "unplugin-auto-import": "^0.17.3",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^7.1.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vue": "^3.5.17",
    "vue-tsc": "^3.0.6"
  }
}
