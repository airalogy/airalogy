{
  "name": "@airalogy/aimd-renderer",
  "type": "module",
  "version": "2.12.0",
  "description": "AIMD (Airalogy Markdown) rendering engines for HTML and Vue",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/airalogy/airalogy.git",
    "directory": "packages/npm/aimd-renderer"
  },
  "bugs": {
    "url": "https://github.com/airalogy/airalogy/issues"
  },
  "homepage": "https://github.com/airalogy/airalogy/tree/main/packages/npm/aimd-renderer#readme",
  "keywords": [
    "aimd",
    "markdown",
    "renderer",
    "vue",
    "html"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./html": {
      "types": "./src/html/index.ts",
      "import": "./src/html/index.ts"
    },
    "./vue": {
      "types": "./src/vue/index.ts",
      "import": "./src/vue/index.ts"
    },
    "./styles": {
      "import": "./src/styles/renderer.css",
      "default": "./src/styles/renderer.css"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "build": "vite build && pnpm run build:types",
    "dev": "vite build --watch",
    "test": "pnpm run build && node --test ./tests/*.test.mjs"
  },
  "peerDependencies": {
    "vue": "^3.5.17"
  },
  "dependencies": {
    "@airalogy/aimd-core": "workspace:^",
    "@types/hast": "^3.0.4",
    "hast-util-to-html": "^9.0.5",
    "katex": "catalog:",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^2.5.0",
    "unified": "^11.0.5",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "5.8.3",
    "vite": "^7.1.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vue": "^3.5.17"
  }
}
